{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "go mod tidy && cd backend && go build -o ../server cmd/server/main.go"
  },
  "deploy": {
    "startCommand": "./server"
  },
  "env": {
    "SERVER_PORT": "8080",
    "DATABASE_URL": "${{ DATABASE_URL }}",
    "JWT_SECRET": "${{ JWT_SECRET }}",
    "ADMIN_PASSWORD": "${{ ADMIN_PASSWORD }}"
  }
}
